module top_module(
    input clk,
    input a,
    input b,
    output wire out_assign,
    output reg out_always_comb,
    output reg out_always_ff   
);

    // 1. Звичайний assign (комбінаційна логіка)
    assign out_assign = a ^ b;

    // 2. Комбінаційний always блок
    always @(*) begin
        out_always_comb = a ^ b;
    end

    // 3. ТАКТОВИЙ always блок (Sequential)
    // Використовуємо неблокуюче присвоювання <=
    always @(posedge clk) begin
        out_always_ff <= a ^ b;
    end

endmodule
